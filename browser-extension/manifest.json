{
  "manifest_version": 3,
  "name": "Prompt Helper",
  "version": "1.0",
  "description": "Copy and paste prompt assistant",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
